# MongoDB (Atlas는 기본 TLS 적용, 프로덕션에서 tls=true 강제)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=PocketPay

# Server
PORT=3000
NODE_ENV=development

# JWT (최소 32자 이상의 랜덤 문자열 사용!)
# 생성 예시: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS (쉼표로 구분, 생략시 localhost 기본값)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Naver Clova OCR - Document (영수증)
DOCUMENT_SECRET_KEY=
DOCUMENT_APIGW_URL=

# Naver Clova OCR - General
GENERAL_SECRET_KEY=
GENERAL_APIGW_URL=

# Frontend URL (OAuth 콜백 리다이렉트용)
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/login/oauth/google/callback
GOOGLE_CLIENT_SECRET=

# Sentry (선택 - 에러 모니터링)
SENTRY_DSN=

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_REDIRECT_URI=http://localhost:3000/auth/login/oauth/naver/callback
NAVER_CLIENT_SECRET=
NAVER_STATE=
