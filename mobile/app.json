{
  "expo": {
    "name": "작은 모임",
    "slug": "jageun-moim",
    "version": "1.0.0",
    "scheme": "pocketpay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.jageunmoim.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "영수증 사진을 선택하여 OCR 자동 입력에 사용합니다.",
        "NSPhotoLibraryAddUsageDescription": "거래에 첨부된 영수증을 사진 앨범에 저장합니다.",
        "NSCameraUsageDescription": "영수증을 촬영하여 OCR 자동 입력에 사용합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.jageunmoim.app",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "영수증 사진을 선택하여 거래 내역을 자동으로 입력합니다.",
          "cameraPermission": "영수증을 촬영하여 거래 내역을 자동으로 입력합니다."
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "735c7e41-93e1-4753-b553-837a3d396c84"
      }
    }
  }
}
